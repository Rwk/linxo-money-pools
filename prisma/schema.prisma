generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventType {
  BIRTHDAY
  BIRTH
  WEDDING
  FAREWELL
  OTHER
}

enum PoolStatus {
  OPEN
  CLOSED
}

enum PaymentMethod {
  STANDARD
  INSTANT
}

enum LinxoOrderStatus {
  NEW
  AUTHORIZED
  CLOSED
  REJECTED
  FAILED
  EXPIRED
}

enum LinxoPaymentStatus {
  SUBMITTED
  EXECUTED
  CANCELLED
  REJECTED
}

enum LinxoSettlementStatus {
  IN_PROGRESS
  SETTLED
  MANUALLY_SETTLED
  NO_FUNDS
  TO_CHARGE_BACK
}

enum CashInStatus {
  PENDING
  EXECUTED
  REJECTED
  CANCELLED
  EXPIRED
  COLLECTED
}

enum PaymentLinkOpenedSource {
  QR_CODE
  DIRECT_LINK
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  firstName     String?
  lastName      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  pools         Pool[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pool {
  id                           String         @id @default(cuid())
  slug                         String         @unique
  title                        String
  description                  String
  eventType                    EventType
  status                       PoolStatus     @default(OPEN)
  closingDate                  DateTime
  creatorId                    String
  creator                      User           @relation(fields: [creatorId], references: [id], onDelete: Restrict)
  collectorDisplayName         String
  collectorAuthorizedAccountId String?
  collectorAliasId             String?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  closedAt                     DateTime?
  contributions                Contribution[]

  @@index([creatorId])
}

model Contribution {
  id                    String                 @id @default(cuid())
  poolId                String
  pool                  Pool                   @relation(fields: [poolId], references: [id], onDelete: Cascade)
  paymentAccessToken    String?                @unique
  contributorFirstName  String
  contributorLastName   String
  contributorEmail      String
  amount                Decimal                @db.Decimal(14, 2)
  currency              String                 @default("EUR")
  displayAsAnonymous    Boolean                @default(false)
  hideAmount            Boolean                @default(false)
  selectedPaymentMethod PaymentMethod
  linxoOrderId          String?                @unique
  linxoInstructionId    String?
  linxoPaymentId        String?
  linxoSettlementId     String?
  linxoOrderStatus      LinxoOrderStatus?
  linxoPaymentStatus    LinxoPaymentStatus?
  linxoSettlementStatus LinxoSettlementStatus?
  cashInStatus          CashInStatus           @default(PENDING)
  authUrl               String?
  shortAuthUrl          String?
  paymentLinkOpenedAt   DateTime?
  paymentLinkOpenedSource PaymentLinkOpenedSource?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  returnedAt            DateTime?
  manuallySettledAt     DateTime?

  @@index([poolId])
}
