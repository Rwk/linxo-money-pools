generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventType {
  BIRTHDAY
  BIRTH
  WEDDING
  FAREWELL
  OTHER
}

enum PoolStatus {
  OPEN
  CLOSED
}

enum PaymentMethod {
  STANDARD
  INSTANT
}

enum LinxoOrderStatus {
  NEW
  AUTHORIZED
  CLOSED
  REJECTED
  FAILED
  EXPIRED
}

enum LinxoPaymentStatus {
  SUBMITTED
  EXECUTED
  CANCELLED
  REJECTED
}

enum LinxoSettlementStatus {
  IN_PROGRESS
  SETTLED
  MANUALLY_SETTLED
  NO_FUNDS
  TO_CHARGE_BACK
}

enum CashInStatus {
  PENDING
  EXECUTED
  REJECTED
  CANCELLED
  EXPIRED
  COLLECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pools     Pool[]
}

model Pool {
  id                           String         @id @default(cuid())
  slug                         String         @unique
  title                        String
  description                  String
  eventType                    EventType
  status                       PoolStatus     @default(OPEN)
  closingDate                  DateTime
  creatorId                    String
  creator                      User           @relation(fields: [creatorId], references: [id], onDelete: Restrict)
  collectorDisplayName         String
  collectorAuthorizedAccountId String?
  collectorAliasId             String?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  closedAt                     DateTime?
  contributions                Contribution[]

  @@index([creatorId])
}

model Contribution {
  id                    String                 @id @default(cuid())
  poolId                String
  pool                  Pool                   @relation(fields: [poolId], references: [id], onDelete: Cascade)
  contributorFirstName  String
  contributorLastName   String
  contributorEmail      String
  amount                Decimal                @db.Decimal(14, 2)
  currency              String                 @default("EUR")
  displayAsAnonymous    Boolean                @default(false)
  hideAmount            Boolean                @default(false)
  selectedPaymentMethod PaymentMethod
  linxoOrderId          String?                @unique
  linxoInstructionId    String?
  linxoPaymentId        String?
  linxoSettlementId     String?
  linxoOrderStatus      LinxoOrderStatus?
  linxoPaymentStatus    LinxoPaymentStatus?
  linxoSettlementStatus LinxoSettlementStatus?
  cashInStatus          CashInStatus           @default(PENDING)
  authUrl               String?
  shortAuthUrl          String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  returnedAt            DateTime?
  manuallySettledAt     DateTime?

  @@index([poolId])
}
